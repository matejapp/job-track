# ─────────────────────────────────────────────────────────────
# JobTrack — root environment (used by docker-compose.yml)
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# JWT signing key for the API.
# Generate a strong random secret (do NOT reuse this placeholder):
#   PowerShell:  [Convert]::ToBase64String((1..64 | %{ Get-Random -Max 256 } | %{ [byte]$_ }))
#   bash:        openssl rand -base64 64
JWT_SECRET=replace-with-a-long-random-base64-secret
